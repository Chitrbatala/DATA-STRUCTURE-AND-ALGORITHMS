class Solution {
    public List<String> generateParenthesis(int n) {
        List<String> ans = new ArrayList<>();
        char[] curr = new char[2 * n];
        solve(0, n, 0, 0, curr, ans);
        return ans;
    }
    private void solve(int pos, int n, int open, int close, char[] curr, List<String> ans) {
        if (pos == 2 * n) {
            ans.add(new String(curr));
            return;
        }

        if (open < n) {
            curr[pos] = '(';
            solve(pos + 1, n, open + 1, close, curr, ans);
        }

        if (close < open) {
            curr[pos] = ')';
            solve(pos + 1, n, open, close + 1, curr, ans);
        }
    }
}



