class Solution {
    public List<List<Integer>> subsets(int[] nums) {
        List<List<Integer>> ans = new ArrayList<>();
        sub(0, nums, new ArrayList<>(), ans);
        return ans;
    }
    private void sub(int ind, int[] nums, List<Integer> curr, List<List<Integer>> ans) {
        if (ind == nums.length) {
            ans.add(new ArrayList<>(curr));
            return;
        }

        curr.add(nums[ind]);
        sub(ind + 1, nums, curr, ans);

        // Backtrack
        curr.remove(curr.size() - 1);

        // Don;t take
        sub(ind + 1, nums, curr, ans);
    }
}
