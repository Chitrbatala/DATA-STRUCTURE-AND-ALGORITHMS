class Solution {
    // Function to calculate factorial of a number.
    int factorial(int n) {
        // if (n == 1) {
        //     return 1;
        // }
        // return n * factorial(n - 1);
        int ans = helper(n, 1);
        return ans;
    }
    private int helper(int i, int fact) {
        if (i == 0) {
            return fact;
        }
        return helper(i - 1, fact * i);
    }
}
