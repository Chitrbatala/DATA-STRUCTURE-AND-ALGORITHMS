class Solution {
    ArrayList<Integer> findTwoElement(int arr[]) {
        int n = arr.length;
        
        int[] freq = new int[n];
        
        for (int i = 0; i < n; i++) {
            int index = arr[i] - 1;
            freq[index]++;
        }
        
        ArrayList<Integer> ans = new ArrayList<>();
        
        for (int i = 0; i < freq.length; i++) {
            if (freq[i] == 2) {
                ans.add(i + 1);
            }
        }
        
        for (int i = 0; i < freq.length; i++) {
            if (freq[i] == 0) {
                ans.add(i + 1);
            }
        }
        return ans;
    }
}
