class Solution {
    public int maxScore(int[] cardPoints, int k) {
        int n = cardPoints.length;

        int ls = 0;
        int rs = 0;
        int maxSum = 0;

        for (int i = 0; i < k; i++) {
            ls = ls + cardPoints[i];
            maxSum = ls;
        }

        int rightIndex = n - 1;

        for (int i = k - 1; i >= 0; i--) {
            ls = ls - cardPoints[i];
            rs = rs + cardPoints[rightIndex];
            rightIndex--;

            maxSum = Math.max(maxSum, ls + rs);
        }

        return maxSum;
    }
}
