class Solution {
    public Queue<Integer> reverseFirstK(Queue<Integer> q, int k) {
        if (q == null || k <= 0 || q.size() < k) {
            return q;
        }
        
        Stack<Integer> st = new Stack<>();
        
        for (int i = 0; i < k; i++) {
            st.push(q.poll());
        }
        
        while (!st.isEmpty()) {
            q.offer(st.pop());
        }
        
        int order = q.size() - k;
        
        for (int i = 0; i < order; i++) {
            q.offer(q.poll());
        }
        return q;
    }
}


        
