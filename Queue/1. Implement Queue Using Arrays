class myQueue {
    int start;
    int end;
    int size;
    int currSize;
    int[] q;
    // Constructor
    public myQueue(int n) {
        // Define Data Structures
        start = -1;
        end = -1;
        size = n;
        currSize = 0;
        q = new int[n];
    }

    public boolean isEmpty() {
        // Check if queue is empty
        return start == end == -1;
    }

    public boolean isFull() {
        // Check if queue is full
        return currSize == size;
    }

    public void enqueue(int x) {
        // Enqueue
        if (currSize == size) {
            return;
        }
        if (currSize == 0) {
            start = 0;
            end = 0;
        } else {
            end = (end + 1) % size;
        }
        q[end] = x;
        currSize += 1;
    }

    public void dequeue() {
        // Dequeue
        if (currSize == 0) {
            return;
        }
        int element = q[start];
        if (currSize == 1) {
            start = -1;
            end = -1;
        }
        start = (start + 1) % size;
        return element;
    }

    public int getFront() {
        // Get front element
        if (currSize == 0) {
            return -1;
        }
        return q[start];
    }

    public int getRear() {
        // Get last element
        if (currSize == size) {
            return q[size];
        } 
        return q[end];
    }
}
