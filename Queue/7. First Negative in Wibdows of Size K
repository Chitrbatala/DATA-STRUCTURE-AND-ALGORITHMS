class Solution {
    static List<Integer> firstNegInt(int arr[], int k) {
        List<Integer> ans = new ArrayList<>();
        Queue<Integer> q = new LinkedList<>();
        
        int l = 0;
        
        for (int r = 0; r < arr.length; r++) {
            if (arr[r] < 0) {
                q.add(arr[r]);
            }
            
            if (r - l + 1 == k) {
                if (q.isEmpty()) {
                    ans.add(0);
                } else {
                    ans.add(q.peek());
                }
                
                if (!q.isEmpty() && arr[l] == q.peek()) {
                    q.poll();
                }
                l++;
            }
        }
        return ans;
    }
}

