class Solution {
    static Node deleteAllOccurOfX(Node head, int x) {
        Node temp = head;
        
        while (temp != null) {
            Node nextNode = temp.next;
            
            if (temp.data == x) {
                if (temp.prev == null) {
                    head = temp.next;
                } else {
                    temp.prev.next = temp.next;
                }
                
                if (temp.next != null) {
                    temp.next.prev = temp.prev;
                }
            }
            temp = nextNode;
        }
        return head;
    }
}
