class Solution {
    public static void removeLoop(Node head) {
      Node slow = head;
      Node fast = head;
      
      boolean hasLoop = false;
      
      while (fast != null && fast.next != null) {
          slow = slow.next;
          fast = fast.next.next;
          
          if (slow == fast) {
              hasLoop = true;
              break;
          }
      }
      
      if (!hasLoop) return;
      
      slow = head;
      
      if (slow == fast) {
          while (fast.next != slow) {
              fast = fast.next;
          }
          fast.next = null;
          return;
      }
      
      while (slow.next != fast.next) {
          slow = slow.next;
          fast = fast.next;
      }
      fast.next = null;
      return;
        
    }
}
