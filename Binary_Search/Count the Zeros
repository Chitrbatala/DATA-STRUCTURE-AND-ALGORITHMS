class Solution {
    int countZeroes(int[] arr) {
        int n = arr.length;
        
        int s = 0;
        int e = n - 1;
        
        int ans = 0;
        
        while (s <= e) {
            int m = s + (e - s) / 2;
            
            if (arr[m] == 0) {
                ans = n - m;
                e = m - 1;
            } else {
                s = m + 1;
            }
        }
        return ans;
    }
}
