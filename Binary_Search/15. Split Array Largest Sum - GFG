class Solution {
    public int splitArray(int[] arr, int k) {
        int low = maximum(arr);
        int high = summation(arr);
        
        int ans = -1;
        
        while (low <= high) {
            int mid = low + (high - low) / 2;
            
            int minimumPossible = divide(arr, mid);
            
            if (minimumPossible <= k) {
                ans = mid;
                high = mid - 1;
            } else {
                low = mid + 1;
            }
        }
        return ans;
    }
    private int maximum(int[] arr) {
        int max = arr[0];
        
        for (int i = 0; i < arr.length; i++) {
            max = Math.max(max, arr[i]);
        }
        return max;
    }
    private int summation(int[] arr) {
        int sum = 0;
        
        for (int i = 0; i < arr.length; i++) {
            sum += arr[i];
        }
        return sum;
    }
    private int divide(int[] arr, int limit) {
        int maxi = 1;
        int sum = 0;
        
        for (int i = 0; i < arr.length; i++) {
            if (sum + arr[i] <= limit) {
                sum += arr[i];
            } else {
                maxi++;
                sum = arr[i];
            }
        }
        return maxi;
    }
}
