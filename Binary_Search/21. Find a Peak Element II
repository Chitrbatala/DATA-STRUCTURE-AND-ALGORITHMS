class Solution {
    public int[] findPeakGrid(int[][] mat) {
       int m = mat.length;
       int n = mat[0].length;

       int l = 0;
       int h = n - 1;

       while (l <= h) {
        int mid = l + (h - l) / 2;

        int max = mat[0][mid];
        int index = 0;

        for (int i = 1; i < m; i++) {
            if (mat[i][mid] > max) {
                max = mat[i][mid];
                index = i;
            }
        }

        int curr = max;

        int left = (mid > 0) ? mat[index][mid - 1] : Integer.MIN_VALUE;
        int right = (mid < n - 1) ? mat[index][mid + 1] : Integer.MIN_VALUE;

        if (curr > left && curr > right) {
            return new int[]{index, mid};
        } else if (curr < left) {
            h = mid - 1;
        } else {
            l = mid + 1;
        }
       }
       return new int[] {-1, -1};
    }
}






