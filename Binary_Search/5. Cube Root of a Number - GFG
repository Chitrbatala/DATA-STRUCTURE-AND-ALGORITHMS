class Solution {
    static int cubeRoot(int n) {
        if (n == 0 || n == 1) return n;
        int s = 1;
        int e = n;
        int ans = -1;
        
        while (s <= e) {
            int mid = s + (e - s) / 2;
            
            if (mid == n / (mid * mid)) {
                return mid;
            } else if (mid < n / (mid * mid)) {
                ans = mid;
                s = mid + 1;
            } else {
                e = mid - 1;
            }
        }
        return ans;
    }
};
