class Solution {
    public boolean findPair(int[] arr, int x) {
        Arrays.sort(arr);
        
        int n = arr.length;
        
        for (int i = 0; i < n; i++) {
            int target = arr[i] + x;
            
            int low = i + 1;
            int high = n - 1;
            
            while (low <= high) {
                int mid = low + (high - low);
                
                if (arr[mid] == target) {
                    return true;
                } else if (arr[mid] < target) {
                    low = mid + 1;
                } else {
                    high = mid - 1;
                }
            }
        }
        return false;
    }
}
