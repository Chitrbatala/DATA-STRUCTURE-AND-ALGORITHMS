class Solution {
    public int singleNonDuplicate(int[] nums) {
        int n = nums.length;
        int low = 0;
        int high = n - 1;

        while (low < high) {
            int mid = low + (high - low) / 2;
            int pair = nums[mid ^ 1];

            if (nums[mid] != pair) {
                high = mid;
            } else {
                low = mid + 1;
            }
        }
        return nums[low];
    }
}
