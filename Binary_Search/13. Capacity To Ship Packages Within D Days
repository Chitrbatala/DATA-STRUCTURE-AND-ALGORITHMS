class Solution {
    public int shipWithinDays(int[] weights, int days) {
        int low = maximum(weights);
        int high = summation(weights);

        if (days == 1) return high;

        int ans = -1;

        while (low <= high) {
            int mid = low + (high - low) / 2;
            int requiredDays = days(weights, mid);

            if (requiredDays <= days) {
                ans = mid;
                high = mid - 1;
            } else {
                low = mid + 1;
            }
        }
        return ans;
    }
    private int maximum(int[] weights) {
        int max = weights[0];
        for (int i = 0; i < weights.length; i++) {
            max = Math.max(weights[i], max);
        }
        return max;
    }
    private int summation(int[] weights) {
        int sum = 0;
        for (int i = 0; i < weights.length; i++) {
            sum += weights[i];
        }
        return sum;
    }
    private int days(int[] weights, int limit) {
        int days = 1;
        int load = 0;

        for (int i = 0; i < weights.length; i++) {
            if (load + weights[i] <= limit) {
                load += weights[i];
            } else {
                days++;
                load = weights[i];
            }
        }
        return days;
    }
}



