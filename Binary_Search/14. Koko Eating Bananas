class Solution {
    public int minEatingSpeed(int[] piles, int h) {
        int low = 1;
        int high = maximum(piles);

        int ans = -1;

        while (low <= high) {
            int mid = low + (high - low) / 2;

            int hoursRequired = hourly(piles, mid);

            if (hoursRequired <= h) {
                ans = mid;
                high = mid - 1; // try smaller speed
            } else {
                low = mid + 1; // need more speed
            }
        }
        return ans;
    }

    private int maximum(int[] piles) {
        int max = piles[0];
        for (int i = 0; i < piles.length; i++) {
            max = Math.max(max, piles[i]);
        }
        return max;
    }

    private int hourly(int[] piles, int speed) {
        int hours = 0;

        for (int i = 0; i < piles.length; i++) {
            hours += Math.ceil((piles[i] + speed - 1) / speed); // ceil division
        }
        return hours;
    }
}
