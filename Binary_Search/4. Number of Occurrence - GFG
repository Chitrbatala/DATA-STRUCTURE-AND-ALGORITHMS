class Solution {
    int countFreq(int[] arr, int target) {
        int first = lowerBound(arr, target);
        
        if (first == -1) {
            return 0;
        }
        
        int last = upperBound(arr, target);
        
        return last - first + 1;
    }
    private int lowerBound(int[] nums, int target) {
        int s = 0;
        int e = nums.length - 1;
        int ans = -1;
        
        while (s <= e) {
            int mid = s + (e - s) / 2;
            
            if (nums[mid] == target) {
                ans = mid;
                e = mid - 1;
            } else if (nums[mid] < target) {
                s = mid + 1;
            } else {
                e = mid -1;
            }
        }
        return ans;
    }
    private int upperBound(int[] nums, int target) {
        int s = 0;
        int e = nums.length - 1;
        int ans = -1;
        
        while (s <= e) {
            int mid = s + (e - s) / 2;
            if (nums[mid] == target){
                ans = mid;
                s = mid + 1;
            } else if (nums[mid] < target){
                s = mid + 1;
            } else {
                e = mid -1;
            }
        }
        return ans;
    }
}
