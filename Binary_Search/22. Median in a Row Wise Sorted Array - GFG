class Solution {
    public int median(int[][] mat) {
        int m = mat.length;
        int n = mat[0].length;
        
        int low = Integer.MAX_VALUE;
        int high = Integer.MIN_VALUE;
        
        for (int i = 0; i < m; i++) {
            low = Math.min(low, mat[i][0]);
            high = Math.max(high, mat[i][n - 1]);
        }
        
        int required = (m * n) / 2;
        
        while (low <= high) {
            int mid = low + (high - low) / 2;
            
            int count = 0;
            
            for (int i = 0; i < m; i++) {
                count += upperBound(mat[i], mid);
            }
            
            if (count <= required) {
                low = mid + 1;
            } else {
                high = mid - 1;
            }
        }
        return low;
    }
    public int upperBound(int[] row, int target) {
        int l = 0;
        int h = row.length - 1;
        
        while (l <= h) {
            int mid = l + (h - l) / 2;
            
            if (row[mid] <= target) {
                l = mid + 1;
            } else {
                h = mid - 1;
            }
        }
        return l;
    }
}





