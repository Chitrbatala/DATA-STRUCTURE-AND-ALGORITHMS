class Solution {
    public int minAddToMakeValid(String s) {
        Stack<Character> st = new Stack<>();
        int count = 0;
        for (int i = 0; i < s.length(); i++) {
            if (s.charAt(i) == '(') {
                st.push(s.charAt(i));
            }
             else if (!st.isEmpty() && st.peek() == '(' && s.charAt(i) == ')') {
                st.pop();
            } else {
                st.push(s.charAt(i));
            }
        }
        return st.size();
    }
}


