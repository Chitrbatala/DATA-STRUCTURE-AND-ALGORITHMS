class Solution {
    public int largestRectangleArea(int[] heights) {
        int n = heights.length;

        int[] NSR = new int[n];
        int[] NSL = new int[n];

        Stack<Integer> st = new Stack<>();

        for (int i = 0; i < n; i++) {
            while (!st.isEmpty() && heights[st.peek()] > heights[i]) {
                NSR[st.peek()] = i;
                st.pop();
            }
            st.push(i);
        }

        while (!st.isEmpty()) {
            NSR[st.peek()] = n;
            st.pop();
        }

        for (int i = n - 1; i >= 0; i--) {
            while (!st.isEmpty() && heights[st.peek()] > heights[i]) {
                NSL[st.peek()] = i;
                st.pop();
            }
            st.push(i);
        }
        
        while (!st.isEmpty()) {
            NSL[st.peek()] = -1;
            st.pop();
        }

        int ans = 0;

        for (int i = 0; i < n; i++) {
            ans = Math.max(ans, heights[i] * (NSR[i] - NSL[i] - 1));
        }

        return ans;
    }
}
