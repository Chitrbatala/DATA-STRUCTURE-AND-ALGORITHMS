import java.util.Stack;

class SpecialStack {

    Stack<Integer> st;
    Stack<Integer> minSt;

    public SpecialStack() {
        st = new Stack<>();
        minSt = new Stack<>();
    }

    // Push an element
    public void push(int x) {
        st.push(x);

        if (minSt.isEmpty() || x <= minSt.peek()) {
            minSt.push(x);
        } else {
            minSt.push(minSt.peek());
        }
    }

    // Pop the top element
    public void pop() {
        if (!st.isEmpty()) {
            st.pop();
            minSt.pop();
        }
    }

    // Return top element
    public int peek() {
        if (st.isEmpty()) {
            return -1;
        }
        return st.peek();
    }

    // Check if stack is empty
    public boolean isEmpty() {
        return st.isEmpty();
    }

    // Return minimum element
    public int getMin() {
        if (minSt.isEmpty()) {
            return -1;
        }
        return minSt.peek();
    }
}
