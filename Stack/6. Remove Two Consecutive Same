class Solution {
    public int removeConsecutiveSame(String[] arr) {
        
        Stack<String> st = new Stack<>();
        
        for (String word : arr) {
            if (!st.isEmpty() && word.equals(st.peek())) {
                st.pop();
            } else {
                st.push(word);
            }
        }
        return st.size();
    }
};
