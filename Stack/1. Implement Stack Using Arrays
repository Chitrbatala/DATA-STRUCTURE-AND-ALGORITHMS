class myStack {
    int n;
    int[] st;
    int top;
    public myStack(int n) {
        this.n = n;
        top = -1;
        st = new int[n];
    }

    public boolean isEmpty() {
        return top == -1;
    }

    public boolean isFull() {
        return top == n - 1;
    }

    public void push(int x) {
        if (isFull()) {
            return;
        }
        st[++top] = x;
    }

    public void pop() {
        if (isEmpty()) {
            return;
        }
        top--;
    }

    public int peek() {
        if (isEmpty()) {
            return -1;
        }
        return st[top];
    }
}
