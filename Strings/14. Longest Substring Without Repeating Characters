class Solution {
    public int lengthOfLongestSubstring(String s) {
        int n = s.length();
        int ans = 0;

        int[] hash = new int[256];

        int left = 0;

        for (int right = 0; right < n; right++) {
            char ch = s.charAt(right);

            hash[ch]++;

            while (hash[ch] > 1) {
                char leftChar = s.charAt(left);
                hash[leftChar]--;
                left++;
            }

            int currLength = right - left + 1;

            ans = Math.max(ans, currLength);
        }

        return ans;
    }
}

