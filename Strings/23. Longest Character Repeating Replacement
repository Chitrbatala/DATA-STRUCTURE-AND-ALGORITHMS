class Solution {
    public int characterReplacement(String s, int k) {
        int n = s.length();

        int l = 0;
        int[] freq = new int[26];

        int maxLength = 0;
        int maxFreq = 0;

        for (int r = 0; r < n; r++) {
            int index = s.charAt(r) - 'A';
            freq[index]++;

            maxFreq = Math.max(maxFreq, freq[index]);

            while ((r - l + 1) - maxFreq > k) {
                freq[s.charAt(l) - 'A']--;
                l++;
            }
            maxLength = Math.max(maxLength, r - l + 1);
        }
        return maxLength;
    }
}


