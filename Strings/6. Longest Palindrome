class Solution {
    public int longestPalindrome(String s) {
        int n = s.length();

        int[] freq = new int[128];

        for (char ch : s.toCharArray()) {
            freq[ch]++;
        }

        int ans = 0;
        boolean odd = false;

        for (int i = 0; i <= 127; i++) {
            int count = freq[i];

            if (count % 2 == 0) {
                ans += count;
            } else {
                ans += (count - 1);
                odd = true;
            }
        }
        if (odd) {
            ans += 1;
        }
        return ans;
    }
}

