class Solution {
    public int minChar(String s) {
       String rev = new StringBuilder(s).reverse().toString();
       String temp = s + "$" + rev;
       
       int n = temp.length();
       int[] lps = new int[n];
       
       int pre = 0;
       int suff = 1;
       
       while (suff < n) {
           if (temp.charAt(pre) == temp.charAt(suff)) {
               lps[suff] = pre + 1;
               pre++;
               suff++;
           } else {
               if (pre == 0) {
                   lps[suff] = 0;
                   suff++;
               } else {
                   pre = lps[pre - 1];
               }
           }
       }
       
       int longestPalindromicPrefix = lps[n - 1];
       
       return s.length() - longestPalindromicPrefix;
    }
}



