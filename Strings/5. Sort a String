class Solution {
    public String sortString(String s) {
        int n = s.length();
        
        int[] arr = new int[26];
        
        for (int i = 0; i < n; i++) {
            char ch = s.charAt(i);
            
            int index = ch - 'a';
            arr[index]++;
        }
        
        StringBuilder ans = new StringBuilder();
        
        for (int i = 0; i < arr.length; i++) {
            int count = arr[i];
            
            char ch = (char) (i + 'a');
            
            for (int j = 0; j < count; j++) {
                ans.append(ch);
            }
        }
        return ans.toString();
    }
}
