class Solution {
    public boolean checkIfPangram(String sentence) {
        int n = sentence.length();

        if (n < 26) {
            return false;
        }

        HashSet<Character> ans = new HashSet<>();

        for (int i = 0; i < n; i++) {
            char ch = sentence.charAt(i);
            ans.add(ch);

            if (ans.size() == 26) {
                return true;
            }
        } 
        return false;
    }
}


