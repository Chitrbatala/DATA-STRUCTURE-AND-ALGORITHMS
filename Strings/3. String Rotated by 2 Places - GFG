class Solution {
    public static boolean isRotated(String s1, String s2) {
        int n = s1.length();
        
        if (s1.length() != s2.length()) {
            return false;
        }
        
        if (n < 2) {
            return s1.equals(s2);
        }
        
        int k = 2;
        
        String anti = s1.substring(k) + s1.substring(0, k);
        String clock = s1.substring(n - k) + s1.substring(0, n - k);
        
        if (s2.equals(anti) || s2.equals(clock)) {
            return true;
        } 
        return false;
    }
}
