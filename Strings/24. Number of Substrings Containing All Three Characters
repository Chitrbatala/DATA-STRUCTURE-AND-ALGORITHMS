class Solution {
    public int numberOfSubstrings(String s) {
        int n = s.length();

        int count = 0;

        int[] freq = new int[3];

        int l = 0;

        for (int r = 0; r < n; r++) {
            int index = s.charAt(r) - 'a';
            freq[index]++;

            while (freq[0] > 0 && freq[1] > 0 && freq[2] > 0) {
                count += n - r;

                freq[s.charAt(l) - 'a']--;
                l++;
            }
        }
        return count;
    }
}

