class Solution {

    public int repeatedStringMatch(String a, String b) {

        StringBuilder sb = new StringBuilder();

        int count = 0;

        // Repeat until length becomes >= b length
        while (sb.length() < b.length()) {
            sb.append(a);
            count++;
        }

        // First check
        if (kmpSearch(sb.toString(), b)) {
            return count;
        }

        // One extra repetition for overlap case
        sb.append(a);

        if (kmpSearch(sb.toString(), b)) {
            return count + 1;
        }

        return -1;
    }

    private boolean kmpSearch(String text, String pattern) {

        int n = text.length();
        int m = pattern.length();

        int[] lps = buildLPS(pattern);

        int first = 0;
        int second = 0;

        while (first < n) {

            if (text.charAt(first) == pattern.charAt(second)) {
                first++;
                second++;
            } else {

                if (second == 0) {
                    first++;
                } else {
                    second = lps[second - 1];
                }
            }

            // Pattern found
            if (second == m) {
                return true;
            }
        }

        return false;
    }

    private int[] buildLPS(String pattern) {

        int n = pattern.length();

        int[] lps = new int[n];

        int pre = 0;
        int suff = 1;

        while (suff < n) {

            if (pattern.charAt(pre) == pattern.charAt(suff)) {

                lps[suff] = pre + 1;

                pre++;
                suff++;

            } else {

                if (pre == 0) {

                    lps[suff] = 0;
                    suff++;

                } else {

                    pre = lps[pre - 1];
                }
            }
        }

        return lps;
    }
}


