class Solution {
    int getLPSLength(String s) {
        int n = s.length();
        
        int pre = 0;
        int suff = 1;
        
        int[] lps = new int[n];
        
        while (suff < n) {
            if (s.charAt(pre) == s.charAt(suff)) {
                lps[suff] = pre + 1;
                pre++;
                suff++;
            } else {
                if (pre == 0) {
                    lps[suff] = 0;
                    suff++;
                } else {
                    pre = lps[pre - 1];
                }
            }
        }
        return lps[n - 1];
        
    }
}
